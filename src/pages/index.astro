---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import HeroImage from "../assets/images/heroimage.png"
import "../styles/home.css";
import { technologies, techCategories } from "../constants.ts";
import { Image } from "astro:assets";
---

<Layout
  title="Lukáš Netolický | Computer Enthusiast"
  description="High school student who loves coding and tech stuff."
>
  <section class="container hero">
    <Image src={HeroImage} alt="Portrait of Lukáš Netolický, web developer" />
    <div class="hero-section">
      <h1>Hey! I'm <span class="highlight">Lukáš</span></h1>
      <p class="hero-subtitle">
        Student Developer focused on building web apps
      </p>
      <p class="hero-description">
        I'm a student developer who enjoys building fast, functional
        applications using modern tools. I like breaking down complex problems
        and turning them into simple, usable solutions. Right now, I'm exploring
        modern web development and building projects to improve my skills.
      </p>
      <div class="hero-buttons">
        <Link href="/projects/" type="primary">Check Out My Projects</Link>
        <Link href="/contact/" color="secondary">Contact</Link>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="home-section about">
    <div class="container">
      <h2>About Me</h2>
      <div class="about-content">
        <p>
          I'm a student developer who enjoys solving problems and building
          projects that turn ideas into real applications people can use.
          Building projects helps me understand how things really work, and
          that's what keeps me motivated.
        </p>
        <p>
          I'm especially interested in web development, performance, and writing
          clean, maintainable code. I enjoy exploring new tools and technologies
          that help me build better software. Most of my projects use React on
          the frontend, while on the backend I typically work with Go or Hono.
        </p>
      </div>
    </div>
  </section>

  <!-- Technologies Section -->
  <section class="container home-section">
    <h2>Technologies I Work With</h2>
    <p class="home-section-description">
      Here are some of the tools and technologies I use when building projects.
    </p>
    <div class="tech-categories">
      {
        techCategories.map((category) => (
          <div class="tech-category">
            <h3>{category.title}</h3>
            <ul class="tech-list">
              {technologies
                .filter(
                  (tech) => tech.category === category.key && tech.homePage,
                )
                .map((tech) => (
                  <li>
                    {tech.url ? (
                      <a
                        href={tech.url}
                        class="list-item"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={tech.name}
                      >
                        <tech.icon
                          class="tech-icon"
                          class:list={tech.lightModeIcon && "tech-icon-dark"}
                        />
                        {tech.lightModeIcon && (
                          <tech.lightModeIcon class="tech-icon tech-icon-light" />
                        )}
                      </a>
                    ) : (
                      <div class="list-item" aria-label={tech.name}>
                        <tech.icon
                          class="tech-icon"
                          class:list={tech.lightModeIcon && "tech-icon-dark"}
                        />
                        {tech.lightModeIcon && (
                          <tech.lightModeIcon class="tech-icon tech-icon-light" />
                        )}
                      </div>
                    )}
                  </li>
                ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
