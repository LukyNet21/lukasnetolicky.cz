---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import Badge from "../components/Badge.astro";
import SectionDots from "../components/SectionDots.astro";
import "../styles/about.css";

import ITE from "../assets/images/about/ITE.png";
import I2CS from "../assets/images/about/I2CS.png";
import { technologies, techCategories } from "../constants";
---

<Layout
  title="About Me | Lukáš Netolický"
  description="Learn more about my background, interests, and journey as a student developer."
>
  <SectionDots />
  <div>
    <section class="page-header">
      <h1>About <span class="highlight">Me</span></h1>
      <p class="subtitle">My coding journey</p>
    </section>

    <section class="about-content">
      <div class="section">
        <h2 id="who-am-i">Who Am I?</h2>
        <p>
          Hey! I'm a full-stack student developer based in the Czech Republic
          who focuses on full-stack web development. I build web applications
          using React or Astro on the frontend and Go or Hono on the backend for
          fast, reliable APIs.
        </p>
        <p>
          I enjoy solving real problems and turning them into tools people can
          actually use. I'm always exploring new technologies that help me build
          better, cleaner, and more efficient solutions.
        </p>
      </div>

      <div class="section">
        <h2 id="how-i-got-started">How I Got Started</h2>
        <p>
          I got into coding around 2020 by experimenting with small projects and
          game modifications, especially building plugins for games like
          Minecraft. At first it was just curiosity and fun, but once I realized
          I could create things that actually worked and solved problems, that’s
          when I became genuinely interested in programming.
        </p>
        <p>
          Since then I've shifted more into web development, building full-stack
          applications and learning whatever technologies a project requires. I
          enjoy figuring things out as I go, turning ideas into real, working
          software.
        </p>
      </div>
    </section>

    <section class="section skills-section">
      <div class="about-content">
        <h2 id="skills">Skills</h2>

        <div>
          <h3>Technologies I Use</h3>
          <p class="section-description">
            These are the tools and technologies I use to build my projects. I
            am constantly learning and exploring new ones to improve my skills.
          </p>
          {
            techCategories.map((cat) => (
              <div class="tech-group">
                <h4>{cat.title}</h4>

                <ul class="icon-grid" data-category={cat.key}>
                  {technologies
                    .filter((t) => t.category === cat.key)
                    .map((tech) => (
                      <li aria-label={`${tech.name} icon`}>
                        {tech.url ? (
                          <a
                            class="icon-card item"
                            class:list={{ featured: tech.featured }}
                            href={tech.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`Open ${tech.name} website`}
                            title={tech.name}
                          >
                            <tech.icon
                              class="tech-icon"
                              class:list={
                                tech.lightModeIcon && "tech-icon-dark"
                              }
                            />
                            {tech.lightModeIcon && (
                              <tech.lightModeIcon class="tech-icon tech-icon-light" />
                            )}

                            <span>{tech.name}</span>
                          </a>
                        ) : (
                          <div
                            class="icon-card item"
                            class:list={{ featured: tech.featured }}
                            title={tech.name}
                          >
                            <tech.icon
                              class="tech-icon"
                              class:list={
                                tech.lightModeIcon && "tech-icon-dark"
                              }
                            />
                            {tech.lightModeIcon && (
                              <tech.lightModeIcon class="tech-icon tech-icon-light" />
                            )}

                            <span>{tech.name}</span>
                          </div>
                        )}
                      </li>
                    ))}
                </ul>
              </div>
            ))
          }
        </div>

        <div>
          <h3>Languages I Speak</h3>

          <ul class="language-list">
            <li class="language-item item">
              Czech
              <span class="language-level">(Native)</span>
            </li>

            <li class="language-item item">English</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section about-content">
      <h2 id="education">Education</h2>

      <div class="education-item">
        <a
          href="https://www.delta-skola.cz/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <h3>DELTA High School</h3>
        </a>
        <p class="education-date">2024 - Present</p>
        <p class="education-desc">
          High school focused on programming, software development, and modern
          technologies. Enrolled in <a
            href="https://www.delta-skola.cz/talentovy-program-delta-topgun"
            target="_blank"
            rel="noopener noreferrer">TopGun program</a
          >, for people with IT skills focused on university-level computer
          science topics and practical workshops.
        </p>
      </div>
    </section>

    <section class="section badges-section">
      <div class="about-content">
        <div class="certifications">
          <h2 id="certifications">Certifications</h2>
        </div>
        <div class="badges">
          <Badge
            image={ITE}
            href="https://www.credly.com/badges/9b46baef-0bc1-4397-8a4d-c4ea53082e1a"
            alt="IT Essentials Credly badge"
          />
          <Badge
            image={I2CS}
            href="https://www.credly.com/badges/de0a64f0-8122-4b9a-8bc6-9f1f5a04d480"
            alt="Introduction to Cybersecurity Credly badge"
          />
        </div>
      </div>
    </section>

    <section class="about-content section">
      <h2 id="whats-next">What's Next</h2>
      <p>
        Right now I'm focused on deepening my skills and building more advanced
        applications that combine modern frontend frameworks with efficient
        backend systems. I'm especially interested in projects involving
        performance, and real-world problem solving.
      </p>

      <div class="cta-container">
        <Link href="/projects/" type="primary">View My Projects</Link>
      </div>
    </section>
  </div>
</Layout>
